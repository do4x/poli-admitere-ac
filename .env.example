# Supabase Postgres. Runtime goes through the transaction pooler (:6543,
# pgbouncer=true); prisma migrate / importers use the session pooler (:5432).
# Role: dedicated "prisma" login (BYPASSRLS), not the postgres superuser.
DATABASE_URL=
DIRECT_URL=

# Supabase Auth. Publishable key (sb_publishable_...) is safe client-side.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Absolute origin used in magic-link redirects (no trailing slash).
SITE_URL=http://localhost:3000
# Comma-separated list of emails that get the admin role on login.
ADMIN_EMAILS=

# Resend — review-due digest emails. App runs fine without these (emails become no-ops).
RESEND_API_KEY=
NOTIFY_EMAIL=
RESEND_FROM=
