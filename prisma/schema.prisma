generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["relationJoins"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String          @id // = Supabase auth.users.id (uuid)
  email     String          @unique
  isAdmin   Boolean         @default(false)
  createdAt DateTime        @default(now())
  solutions Solution[]
  attempts  AnswerAttempt[]
  aiMarks   AiMark[]
  hints     HintReveal[]
}

enum ExamKind {
  ADMITERE
  PREADMITERE
}

enum Subject {
  MATE
  INFO
}

model Exam {
  id       String    @id @default(cuid())
  year     Int
  kind     ExamKind
  subject  Subject
  session  String?
  problems Problem[]

  @@unique([year, kind, subject, session])
}

model Problem {
  id            String          @id @default(cuid())
  examId        String
  exam          Exam            @relation(fields: [examId], references: [id])
  number        String
  latex         String
  isDepartajare Boolean         @default(false)
  // Official grila key ("a".."f"), admin-imported. Must NEVER reach the
  // client: every page query that returns problems adds
  // `omit: { correctAnswer: true }`; comparison happens in server actions only.
  correctAnswer String?
  solutions     Solution[]
  attempts      AnswerAttempt[]
  aiMarks       AiMark[]
  hints         HintReveal[]
  tags          Tag[]
  difficulty    Difficulty?
  createdAt     DateTime        @default(now())

  @@unique([examId, number])
}

enum Archetype {
  BRUTAL
  INSIGHT
  GRIND
  TRAP
  TRIVIAL
  STANDARD
}

// Difficulty grading per DIFICULTATE.md v2.0 — a property of the problem, not
// of the user, so one row per problem. Graded offline (the grader must solve
// the problem first) and imported with `npm run import:dificultate`.
// `dRaw` is the real ordering; `level` is the human-facing 0.5★–5★ label,
// stored rather than derived so the DB can sort and filter on it.
model Difficulty {
  problemId     String    @id
  problem       Problem   @relation(fields: [problemId], references: [id], onDelete: Cascade)
  r             Float // recunoaștere, 1..5 step 0.5
  e             Float // execuție, 1..5 step 0.5
  t             Float // capcane / distractori, 0..1
  p             Float // îngustimea drumului, 0..0.5
  k             Float // raritatea cunoștințelor, 0..0.5
  v             Float // verificabilitate, -0.5..0.5
  dRaw          Float
  level         Float // 0.5..5 step 0.5
  bandMargin    Boolean   @default(false) // ≤0.15 de o graniță ⇒ se planifică drept banda superioară
  archetype     Archetype
  targetMinutes Int
  // The reusable recognition rule ("semnal ⟹ mișcare"). Deduplicated across
  // problems, this is the finite inventory of patterns that covers the exam.
  trigger       String?
  uncertain     Boolean   @default(false) // necesită re-scorare manuală
  gradedAt      DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([level])
}

// One per (user, problem): "am rezolvat cu AI" — declared with or without an
// uploaded solution. dueAt = markedAt + 72h. Past dueAt the problem resets to
// unsolved and its AI solutions hide, until redeemed: a correct grila answer
// after dueAt (never after a reveal) or an independent upload stamps
// redeemedAt, which restores the solutions and settles the final state.
model AiMark {
  id         String    @id @default(cuid())
  problemId  String
  problem    Problem   @relation(fields: [problemId], references: [id])
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  markedAt   DateTime  @default(now())
  dueAt      DateTime
  notifiedAt DateTime? // review digest dedupe
  redeemedAt DateTime?

  @@unique([problemId, userId])
  @@index([userId])
}

enum AttemptKind {
  CHOICE
  REVEAL
}

model AnswerAttempt {
  id        String      @id @default(cuid())
  problemId String
  problem   Problem     @relation(fields: [problemId], references: [id])
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind      AttemptKind
  choice    String? // "a".."f" when kind = CHOICE
  correct   Boolean? // server-computed at submit time
  createdAt DateTime    @default(now())

  @@index([userId, problemId])
}

// One row per hint a user opened on a problem. Hints are the two halves of the
// grading's `trigger`: level 1 = the signal to spot, level 2 = the move.
// A reveal is permanent and, like AnswerAttempt.REVEAL, taints every LATER
// grila answer — after a hint, a correct choice no longer proves anything.
model HintReveal {
  id         String   @id @default(cuid())
  problemId  String
  problem    Problem  @relation(fields: [problemId], references: [id])
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  level      Int // 1 = semnalul, 2 = mișcarea
  revealedAt DateTime @default(now())

  @@unique([problemId, userId, level])
  @@index([userId])
}

model Tag {
  id        String    @id @default(cuid())
  name      String
  subject   Subject
  problems  Problem[]
  createdAt DateTime  @default(now())

  @@unique([subject, name])
}

model Solution {
  id          String    @id @default(cuid())
  problemId   String
  problem     Problem   @relation(fields: [problemId], references: [id])
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  pdfPath     String // Supabase Storage object path: {userId}/{problemId}/{ts}.pdf
  sizeBytes   Int       @default(0) // for the per-user quota
  submittedAt DateTime  @default(now())
  aiAssisted  Boolean   @default(false)
  // LEGACY (pre-2026-07-18): review scheduling moved to AiMark. Kept so the
  // previous deploy keeps working during rollout; drop in a later migration.
  reviewDueAt DateTime?
  notifiedAt  DateTime?

  @@index([userId])
}
