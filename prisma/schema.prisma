generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String          @id // = Supabase auth.users.id (uuid)
  email     String          @unique
  isAdmin   Boolean         @default(false)
  createdAt DateTime        @default(now())
  solutions Solution[]
  attempts  AnswerAttempt[]
}

enum ExamKind {
  ADMITERE
  PREADMITERE
}

enum Subject {
  MATE
  INFO
}

model Exam {
  id       String    @id @default(cuid())
  year     Int
  kind     ExamKind
  subject  Subject
  session  String?
  problems Problem[]

  @@unique([year, kind, subject, session])
}

model Problem {
  id            String          @id @default(cuid())
  examId        String
  exam          Exam            @relation(fields: [examId], references: [id])
  number        String
  latex         String
  isDepartajare Boolean         @default(false)
  // Official grila key ("a".."f"), admin-imported. Must NEVER reach the
  // client: every page query that returns problems adds
  // `omit: { correctAnswer: true }`; comparison happens in server actions only.
  correctAnswer String?
  solutions     Solution[]
  attempts      AnswerAttempt[]
  tags          Tag[]
  createdAt     DateTime        @default(now())

  @@unique([examId, number])
}

enum AttemptKind {
  CHOICE
  REVEAL
}

model AnswerAttempt {
  id        String      @id @default(cuid())
  problemId String
  problem   Problem     @relation(fields: [problemId], references: [id])
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind      AttemptKind
  choice    String? // "a".."f" when kind = CHOICE
  correct   Boolean? // server-computed at submit time
  createdAt DateTime    @default(now())

  @@index([userId, problemId])
}

model Tag {
  id        String    @id @default(cuid())
  name      String
  subject   Subject
  problems  Problem[]
  createdAt DateTime  @default(now())

  @@unique([subject, name])
}

model Solution {
  id          String    @id @default(cuid())
  problemId   String
  problem     Problem   @relation(fields: [problemId], references: [id])
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  pdfPath     String // Supabase Storage object path: {userId}/{problemId}/{ts}.pdf
  sizeBytes   Int       @default(0) // for the per-user quota
  submittedAt DateTime  @default(now())
  aiAssisted  Boolean   @default(false)
  reviewDueAt DateTime?
  notifiedAt  DateTime?

  @@index([userId])
}
